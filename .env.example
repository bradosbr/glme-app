# Banco de dados MySQL (obrigatório para cadastro de importadores e recintos)
# Exemplo local: mysql://root:senha@localhost:3306/glme
DATABASE_URL=mysql://root:senha@localhost:3306/glme

# Porta do servidor (padrão: 3000)
PORT=3000

# Chave JWT para cookies de sessão
JWT_SECRET=troque-por-uma-chave-secreta-aleatoria

# ID do app (opcional)
# VITE_APP_ID=
